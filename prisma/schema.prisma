generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//===================AUTH===================

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revoked   Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                        String     @id @default(uuid())
  email                     String     @unique
  password                  String
  name                      String
  birthdate                 DateTime?
  language                  String?    @default("indeterminado")
  timezone                  String?    @default("UTC")
  phone                     String?    @default("sin_telefono")
  username                  String     @unique @default("default_username")
  status                    UserStatus @default(ACTIVE)
  role                      Role       @default(USER)
  permissions               String[]   @default([]) // Permisos granulares
  lastLoginAt               DateTime?
  lastLoginIp               String?
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @default(now()) @updatedAt
  verified                  Boolean    @default(false)
  verifyToken               String?
  verifyTokenExpires        DateTime?
  avatarUrl                 String?
  passwordChangedAt         DateTime?
  passwordResetToken        String?
  passwordResetTokenExpires DateTime?

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  accessProfileId String?
  accessProfile   AccessProfile? @relation(fields: [accessProfileId], references: [id])

  clients                    Client[]
  orders                     Order[]
  products                   Product[]
  refreshTokens              RefreshToken[]
  cashSessions               CashSession[]
  cashMovements              CashMovement[]
  storeUsers                 StoreUsers[]
  stores                     Store[]
  storeProducts              StoreProduct[]
  inventoryMovements         InventoryMovement[]
  inventorySessions          InventoryCountSession[]
  warehouseMovements         WarehouseMovement[]
  warehouseCountSessions     WarehouseCountSession[]
  storeReceptionsCreated     StoreReception[]
  warehouseReceptionsCreated WarehouseReception[]
  quotationsCreated          Quotation[]
  storeServicesCreated       StoreService[]
  servicesDefinitionsCreated ServiceDefinition[]
  orderHardDeleteAudits      OrderHardDeleteAudit[]

  supportTicketsCreated               SupportTicket[] @relation("SupportTicketCreatedBy")
  warehousesCreated                   Warehouse[]     @relation("WarehouseCreatedBy")
  supplyOrders                        SupplyOrder[]   @relation("SupplyOrderCreatedBy")
  provider                            Provider[]      @relation("ProviderCreatedBy")
  employed                            Employed?       @relation("EmployedUser")
  employedCreated                     Employed[]      @relation("EmployedCreatedBy")
  employedHistoriesCreated            EmployedHistory[] @relation("EmployedHistoryCreatedBy")
  employedHistoriesUpdated            EmployedHistory[] @relation("EmployedUpdatedBy")
  ordersCanceled                      Order[]         @relation("OrderCanceledBy")
  employeeDocumentsUpdated            EmployeeDocument[] @relation("EmployeeDocumentUpdatedBy")

  paymentMethodsCreated               PaymentMethod[] @relation("PaymentMethodCreatedBy")

  stockTransfersCreated   StockTransfer[] @relation("StockTransferCreatedBy")
  stockTransfersConfirmed StockTransfer[] @relation("StockTransferConfirmedBy")
  stockTransfersCancelled StockTransfer[] @relation("StockTransferCancelledBy")
}

//===================PERFILES DE ACCESO===================

model AccessProfile {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Lista de permisos (keys: VIEW_INVENTORY, MANAGE_PRODUCTS, etc)
  permissions String[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

//===================EMPRESA / TENANT===================

model Tenant {
  id             String          @id @default(uuid())
  name           String
  ruc            String?
  logoUrl        String?
  status         TenantStatus    @default(ACTIVE)
  plan           TenantPlan      @default(FREE)
  features       TenantFeature[]
  defaultService ServiceType?    @default(MISELANEOUS)
  currency       CurrencyCode?   @default(PEN)
  createdAt      DateTime        @default(now())

  stores     Store[]
  warehouses Warehouse[]

  users   User[]
  clients Client[]

  storeProducts       StoreProduct[]
  warehouseProducts   WarehouseProduct[]
  warehouseMovements  WarehouseMovement[]
  inventoryMovements  InventoryMovement[]
  supplyOrders        SupplyOrder[]
  stockTransfers      StockTransfer[]
  warehouseReceptions WarehouseReception[]
  storeReceptions     StoreReception[]
  accessProfiles      AccessProfile[]
  storeServices       StoreService[]
  serviceCategories   ServiceCategory[]
  serviceDefinitions  ServiceDefinition[]
}

//===================TIENDAS===================

model Store {
  id      String  @id @default(uuid())
  name    String
  address String?
  phone   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  cashSessions      CashSession[]
  storeUsers        StoreUsers[]
  storeProducts     StoreProduct[]
  inventoryMovements InventoryMovement[]
  inventorySessions InventoryCountSession[]
  storeEmployees    StoreEmployed[]
  warehouseStores   WarehouseStore[]
  storeReceptions   StoreReception[]
  supplyOrders      SupplyOrder[]
  storeServices     StoreService[]

  stockTransfersAsOrigin      StockTransfer[] @relation("StockTransferOriginStore")
  stockTransfersAsDestination StockTransfer[] @relation("StockTransferDestinationStore")
}

model StoreUsers {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model StoreEmployed {
  id String @id @default(uuid())

  employedId String
  employed   Employed @relation(fields: [employedId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  role       String?
  assignedAt DateTime @default(now())

  @@unique([employedId, storeId])
}

//===================RECEPCIONES DE TIENDA=======================

model StoreReception {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  supplyOrderId String?
  supplyOrder   SupplyOrder? @relation(fields: [supplyOrderId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  receivedAt DateTime @default(now())
  reference  String?
  notes      String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  products StoreReceptionProduct[]

  createdAt DateTime @default(now())
}

//=================== STORE RECEPTION PRODUCTS ===================

model StoreReceptionProduct {
  id String @id @default(uuid())

  storeReceptionId String
  storeReception   StoreReception @relation(fields: [storeReceptionId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int

  createdAt DateTime @default(now())
}

//===================CLIENTES===================

model Client {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  phone     String?
  address   String?
  ruc       String?
  dni       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  orders Order[]

  @@unique([tenantId, dni])
  @@unique([tenantId, email])
  @@unique([tenantId, ruc])
}

//===================PRODUCTOS===================

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  basePrice   Decimal? // precio de venta sugerido
  buyCost     Decimal? // costo de adquisición del producto
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String? // si quieres registrar quién lo creó
  createdBy   User?    @relation(fields: [createdById], references: [id])

  storeProducts       StoreProduct[]
  supplyOrderProducts SupplyOrderProduct[]
  providerProducts    ProviderProduct[]
  warehouseProducts   WarehouseProduct[]
  warehouseReceptions WarehouseReceptionProduct[]
  storeReceptions     StoreReceptionProduct[]
  stockTransferProducts StockTransferProduct[]
}

//=================== Store Products ===================

model StoreProduct {
  id             String   @id @default(uuid())
  price          Decimal // precio que esta tienda aplica
  stock          Int      @default(0) // unidades disponibles en esta tienda
  stockThreshold Int      @default(1) // alerta de stock mínimo
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  orderProducts       OrderProduct[]
  inventoryMovements  InventoryMovement[]
  inventoryCountItems InventoryCountItem[]
  productBatches      ProductBatch[]
}

//=================== Product Batches ===================

model ProductBatch {
  id String @id @default(uuid())

  warehouseProductId String?
  warehouseProduct   WarehouseProduct? @relation(fields: [warehouseProductId], references: [id])

  storeProductId String?
  storeProduct   StoreProduct? @relation(fields: [storeProductId], references: [id])

  quantity Int

  productionDate DateTime?
  expirationDate DateTime?

  receivedAt DateTime @default(now())

  createdAt DateTime @default(now())
}

//===================VENTAS / ORDENES===================

model Order {
  id              String     @id @default(uuid())
  orderNumber     String     @unique
  totalAmount     Decimal
  status          SaleStatus @default(PENDING)
  isPriceModified Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now()) @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  cashSessionsId String?
  cashSession    CashSession? @relation(fields: [cashSessionsId], references: [id])

  cashMovements      CashMovement[]
  inventoryMovements InventoryMovement[]
  orderProducts      OrderProduct[]
  services           Service[]
  paymentMethods     PaymentMethod[]

  // auditoría de anulaciones
  canceledAt   DateTime?
  canceledById String?
  canceledBy   User?     @relation("OrderCanceledBy", fields: [canceledById], references: [id])
}

model OrderProduct {
  id        String       @id @default(uuid())
  quantity  Int          @default(1)
  price     Decimal
  buycost   Decimal      @default(0)
  productId String
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])
  product   StoreProduct @relation(fields: [productId], references: [id])
}

//===================PAGOS===================

model Payment {
  id     String      @id @default(uuid())
  type   PaymentType @default(EFECTIVO)
  amount Decimal

  sourceType PaymentSourceType
  sourceId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentMethod {
  id     String      @id @default(uuid())
  type   PaymentType @default(EFECTIVO)
  amount Decimal

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  createdById String?
  createdBy   User?   @relation("PaymentMethodCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================CAJA===================

model CashSession {
  id             String        @id @default(uuid())
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  openedById     String
  closedById     String?
  status         SessionStatus @default(OPEN)
  openingAmount  Decimal
  declaredAmount Decimal       @default(0)
  closingAmount  Decimal?

  StoreId String
  Store   Store  @relation(fields: [StoreId], references: [id])

  UserId String
  User   User   @relation(fields: [UserId], references: [id])

  // relaciones
  cashMovements CashMovement[]
  orders        Order[]
}

model CashMovement {
  id          String       @id @default(uuid())
  sessionId   String
  type        MovementType
  amount      Decimal
  payment     PaymentType?
  description String?
  createdAt   DateTime     @default(now())

  relatedOrderId String?
  order          Order?  @relation(fields: [relatedOrderId], references: [id])

  CashSessionId String
  CashSession   CashSession @relation(fields: [CashSessionId], references: [id])

  UserId String
  User   User   @relation(fields: [UserId], references: [id])
}

//===================SERVICIOS===================

model Service {
  id                            String        @id @default(uuid())
  type                          ServiceType   @default(MISELANEOUS)
  status                        ServiceStatus @default(IN_PROGRESS)
  name                          String
  description                   String
  photoUrls                     String[]      @default([])
  price                         Decimal
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt

  storeServiceId                String?
  storeService                  StoreService? @relation(fields: [storeServiceId], references: [id])

  serviceCategoryId             String?
  serviceCategory               ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])

  orderId                       String
  order                         Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

//===================SERVICIOS PERSONALIZADOS===================

model StoreService {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal
  type        ServiceType

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  ServiceDefinitionId String
  ServiceDefinition   ServiceDefinition @relation(fields: [ServiceDefinitionId], references: [id])

  ServiceCategoryId String?
  ServiceCategory   ServiceCategory? @relation(fields: [ServiceCategoryId], references: [id])

  services Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================CATEGORIAS DE SERVICIOS===================

model ServiceCategory {
  id   String @id @default(uuid())
  name String

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  isActive Boolean @default(true)

  services      Service[]
  storeServices StoreService[]

  createdAt DateTime @default(now())
}

//===================DEFINICION DE SERVICIOS===================

model ServiceDefinition {
  id          String  @id @default(uuid())
  name        String
  description String?
  basePrice   Decimal

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  StoreService StoreService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================INVENTARIO===================

model InventoryMovement {
  id          String                @id @default(uuid())
  type        InventoryMovementType
  quantity    Int
  description String?
  date        DateTime              @default(now())

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // relación con StoreProduct (producto en una tienda específica)
  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // usuario que realizó el movimiento
  userId String
  user   User   @relation(fields: [userId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])
}

model InventoryCountSession {
  id          String    @id @default(uuid())
  name        String
  createdAt   DateTime  @default(now())
  finalizedAt DateTime?
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  items InventoryCountItem[]
}

model InventoryCountItem {
  id            String   @id @default(uuid())
  expectedStock Int // lo que el sistema dice que deberia haber
  physicalStock Int // lo que el trabajador conto
  difference    Int // physical - expected
  createdAt     DateTime @default(now())

  sessionId String
  session   InventoryCountSession @relation(fields: [sessionId], references: [id])

  storeProductId String
  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id])
}

//===================PROVEEDORES=======================

model Provider {
  id      String  @id @default(uuid())
  name    String
  ruc     String?
  phone   String?
  email   String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  createdById String
  createdBy   User   @relation("ProviderCreatedBy", fields: [createdById], references: [id])

  supplyOrders     SupplyOrder[]
  providerProducts ProviderProduct[]

  @@unique([createdById, ruc])
}

//===================PRODUCTOS DEL PROVEEDOR=======================

model ProviderProduct {
  id String @id @default(uuid())

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  buyCost Decimal?

  @@unique([providerId, productId])
}

//===================ORDENES DE SUMINISTRO=======================

model SupplyOrder {
  id          String            @id @default(uuid())
  code        String
  sequence    Int?
  status      SupplyOrderStatus @default(PENDING)

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  createdById String
  createdBy   User   @relation("SupplyOrderCreatedBy", fields: [createdById], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // productos de la orden
  products SupplyOrderProduct[]

  warehouseReceptions WarehouseReception[]
  storeReceptions     StoreReception[]

  @@unique([createdById, code])
  @@unique([tenantId, providerId, sequence])
}

//===================PRODUCTOS DE LA ORDEN=======================

model SupplyOrderProduct {
  id String @id @default(uuid())

  supplyOrderId String
  supplyOrder   SupplyOrder @relation(fields: [supplyOrderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  note     String?

  @@unique([supplyOrderId, productId])
}

//===================TRANSFERENCIAS DE STOCK===================

model StockTransfer {
  id     String              @id @default(uuid())
  code   String // código legible: TRF-0001
  status StockTransferStatus @default(PENDING)
  notes  String?

  // ORIGEN
  originType        EstablishmentType
  originStoreId     String?
  originStore       Store?     @relation("StockTransferOriginStore", fields: [originStoreId], references: [id])
  originWarehouseId String?
  originWarehouse   Warehouse? @relation("StockTransferOriginWarehouse", fields: [originWarehouseId], references: [id])

  // DESTINO
  destinationType        EstablishmentType
  destinationStoreId     String?
  destinationStore       Store?     @relation("StockTransferDestinationStore", fields: [destinationStoreId], references: [id])
  destinationWarehouseId String?
  destinationWarehouse   Warehouse? @relation("StockTransferDestinationWarehouse", fields: [destinationWarehouseId], references: [id])

  // TENANT
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // AUDITORÍA
  createdById String
  createdBy   User   @relation("StockTransferCreatedBy", fields: [createdById], references: [id])

  confirmedById String?
  confirmedBy   User?    @relation("StockTransferConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt   DateTime?

  cancelledById String?
  cancelledBy   User?    @relation("StockTransferCancelledBy", fields: [cancelledById], references: [id])
  cancelledAt   DateTime?
  cancelReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items StockTransferProduct[]
}

model StockTransferProduct {
  id String @id @default(uuid())

  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantityRequested Int  // cantidad que se pidió transferir
  quantityReceived  Int? // cantidad que realmente llegó (se llena al confirmar)

  createdAt DateTime @default(now())
}

//===================WAREHOUSE===================

model Warehouse {
  id      String  @id @default(uuid())
  name    String
  address String?
  phone   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdById String?
  createdBy   User?   @relation("WarehouseCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  warehouseEmployees  WarehouseEmployed[]
  warehouseStores     WarehouseStore[]
  warehouseProducts   WarehouseProduct[]
  warehouseReceptions WarehouseReception[]
  warehouseMovements  WarehouseMovement[]
  warehouseSessions   WarehouseCountSession[]
  supplyOrders        SupplyOrder[]

  stockTransfersAsOrigin      StockTransfer[] @relation("StockTransferOriginWarehouse")
  stockTransfersAsDestination StockTransfer[] @relation("StockTransferDestinationWarehouse")
}

//===================PRODUCTOS DEL ALMACEN=======================

model WarehouseProduct {
  id String @id @default(uuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  stock          Int @default(0)
  stockThreshold Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productBatches ProductBatch[]
  warehouseMovements WarehouseMovement[]
  warehouseCountItems WarehouseCountItem[]

  @@unique([warehouseId, productId])
}

//===================MOVIMIENTOS DE ALMACÉN=======================

model WarehouseMovement {
  id          String                @id @default(uuid())
  type        InventoryMovementType
  quantity    Int
  description String?
  date        DateTime              @default(now())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  warehouseProductId String
  warehouseProduct   WarehouseProduct @relation(fields: [warehouseProductId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

//===================SESIÓN DE INVENTARIO (ALMACÉN)=======================

model WarehouseCountSession {
  id          String    @id @default(uuid())
  name        String
  createdAt   DateTime  @default(now())
  finalizedAt DateTime?

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  items WarehouseCountItem[]
}

//===================ITEMS DE INVENTARIO (ALMACÉN)=======================

model WarehouseCountItem {
  id            String   @id @default(uuid())
  expectedStock Int // lo que el sistema dice que deberia haber
  physicalStock Int // lo que el trabajador conto
  difference    Int // physical - expected
  createdAt     DateTime @default(now())

  sessionId String
  session   WarehouseCountSession @relation(fields: [sessionId], references: [id])

  warehouseProductId String
  warehouseProduct   WarehouseProduct @relation(fields: [warehouseProductId], references: [id])
}

//===================RECEPCIONES DE ALMACÉN=======================

model WarehouseReception {
  id String @id @default(uuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  supplyOrderId String?
  supplyOrder   SupplyOrder? @relation(fields: [supplyOrderId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  receivedAt DateTime @default(now())
  reference  String? // guia, factura, remito, etc
  notes      String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  products WarehouseReceptionProduct[]

  createdAt DateTime @default(now())
}

//===================WAREHOUSE RECEPTION===================

model WarehouseReceptionProduct {
  id String @id @default(uuid())

  warehouseReceptionId String
  warehouseReception   WarehouseReception @relation(fields: [warehouseReceptionId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int

  createdAt DateTime @default(now())
}

//===================EMPLEADOS DEL ALMACEN=======================

model WarehouseEmployed {
  id String @id @default(uuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  employedId String
  employed   Employed @relation(fields: [employedId], references: [id])

  role       String?
  assignedAt DateTime @default(now())

  @@unique([warehouseId, employedId])
}

model WarehouseStore {
  id String @id @default(uuid())

  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  priority  Int?
  createdAt DateTime @default(now())

  @@unique([warehouseId, storeId])
}

//===================EMPLEADOS===================

model Employed {
  id                                String @id @default(uuid())

  firstName                         String
  lastName                          String

  document                          String?
  phone                             String?
  email                             String?

  position                          String?
  status                            EmployedStatus @default(ACTIVE)
  
  //soft delete
  deletedAt                         DateTime?

  // acceso al sistema (opcional)
  userId                            String? @unique
  user                              User?   @relation("EmployedUser", fields: [userId], references: [id])

  // documentos
  documents                         EmployeeDocument[]

  // auditoria
  createdByUserId                   String
  createdByUser                     User   @relation("EmployedCreatedBy", fields: [createdByUserId], references: [id])

  // relaciones de historia
  employedHistories                 EmployedHistory[]

  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  warehouseAssignments              WarehouseEmployed[]
  storeAssignments                  StoreEmployed[]

  @@unique([createdByUserId, document])
}

enum EmployedStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

//===================EMPLOYED DOCUMENTS===================

model EmployeeDocument {
  id                             String @id @default(uuid())
  url                            String
  originalName                   String
  mimeType                       String
  status                         DocumentStatus @default(ACTIVE)
  size                           Int

  employedId                     String
  employed                       Employed @relation(fields: [employedId], references: [id])

  updatedByUserId                String?
  updatedByUser                  User?   @relation("EmployeeDocumentUpdatedBy", fields: [updatedByUserId], references: [id])

  createdAt                      DateTime @default(now())
}

enum DocumentStatus {
  ACTIVE
  INACTIVE
  DELETED
}

//===================EMPLOYED HISTORY===================

model EmployedHistory {
  id String @id @default(uuid())

  employedId String
  employed   Employed @relation(fields: [employedId], references: [id])

  hiredAt DateTime
  endedAt DateTime?

  reason String? // renuncia, despido, reingreso, etc

  updatedByUserId String?
  updatedByUser   User?   @relation("EmployedUpdatedBy", fields: [updatedByUserId], references: [id])

  createdById String
  createdBy   User   @relation("EmployedHistoryCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

//===================COTIZACIONES===================

model Quotation {
  id        String          @id @default(uuid())
  code      String          @unique
  status    QuotationStatus @default(DRAFT)
  notes     String?
  subtotal  Decimal
  tax       Decimal         @default(0)
  total     Decimal
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items QuotationItem[]
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

//===================COTIZACIONES ITEM===================

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  type QuotationItemType // PRODUCT | SERVICE

  name        String
  description String?
  quantity    Int     @default(1)

  unitPrice Decimal
  subtotal  Decimal

  buycost   Decimal  @default(0) // solo aplica a productos
  photoUrls String[] @default([])

  // referencias historicas (opcional)
  productId String?
  serviceId String?
}

enum QuotationItemType {
  PRODUCT
  SERVICE
}

//===================SUPPORT===================

model SupportTicket {
  id      String @id @default(uuid())
  subject String
  message String

  status   SupportStatus   @default(OPEN)
  priority SupportPriority @default(NORMAL)

  createdByUserId String?
  createdByUser   User?   @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  CANCELLED
  REFUSED
  COMPLETED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
}

//===================AUDITORIA DE BORRADO EN MASIVO===================

model OrderHardDeleteAudit {
  id                String   @id @default(uuid())
  tenantId           String

  executedByUserId   String
  executedByUser     User     @relation(fields: [executedByUserId], references: [id], onDelete: Restrict)
  executedByEmail    String

  fromDate           DateTime
  toDate             DateTime

  deletedOrdersCount Int

  ipAddress          String?
  reason             String?

  createdAt          DateTime @default(now())

  @@index([tenantId, createdAt])
}

//===================SECCIÓN DE METRICAS===================

model ApiMetric {
  id String @id @default(uuid())

  intervalStart   DateTime // inicio del intervalo (ej. minuto)
  intervalMinutes Int      @default(1)

  endpoint String // ruta normalizada: /orders/:id
  method   String // GET, POST, etc

  requestsCount Int
  errorsCount   Int
  avgLatencyMs  Decimal?

  tenantId String? // relacion logica, no FK

  createdAt DateTime @default(now())

  @@index([intervalStart])
  @@index([endpoint])
  @@index([tenantId])
}

